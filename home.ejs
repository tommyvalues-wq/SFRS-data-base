*{box-sizing:border-box}body{margin:0;font-family:Inter,Arial,sans-serif;background:#101113;color:#fff}.topbar{height:106px;background:#0d0d0e;border-top:5px solid #b30011;border-bottom:1px solid #7c1118;display:flex;align-items:center;justify-content:space-between;padding:0 42px}.brand{display:flex;align-items:center;gap:18px;color:white;text-decoration:none}.crest{width:68px;height:68px;border-radius:50%;background:#b40000;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:22px}.brand h1{margin:0;font-size:25px;letter-spacing:.4px}.brand span,footer span{color:#e21b23}.brand p{margin:7px 0 0;color:#bbb;font-size:14px;letter-spacing:2px}nav{display:flex;align-items:center;gap:26px}nav a{color:white;text-decoration:none;font-weight:900;text-transform:uppercase}.nav-btn,.primary-btn,.btn{background:#c1121f;color:white;border:0;border-radius:5px;padding:14px 22px;font-weight:900;text-decoration:none;display:inline-block;cursor:pointer}.hero{min-height:590px;background:linear-gradient(90deg,#060606 0%,#090909 45%,rgba(0,0,0,.48)),url('https://images.unsplash.com/photo-1605705658744-45f0fe8ecaca?auto=format&fit=crop&w=1800&q=80');background-size:cover;background-position:center;display:flex;align-items:center;padding:80px 90px;border-bottom:1px solid #333}.hero-content{max-width:720px}.eyebrow{color:#e21b23;font-weight:900;letter-spacing:2.4px;text-transform:uppercase}.center{text-align:center}.hero h2{font-size:58px;line-height:1.04;margin:14px 0;text-transform:uppercase}.hero h3{font-size:25px;margin:0 0 30px}.hero-main{font-size:22px}.hero-muted{font-size:19px;color:#ccc;line-height:1.5}.primary-btn{margin-top:18px;padding:18px 30px;text-transform:uppercase}.modules,.page{padding:45px 60px;background:#151515;min-height:calc(100vh - 150px)}.modules h2,.page h2{font-size:32px;margin-top:0}.module-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;text-align:left}.module-card,.card{border:1px solid #333;background:#1b1b1b;padding:24px;border-radius:10px;box-shadow:0 20px 50px rgba(0,0,0,.25)}.icon{font-size:40px}.module-card p,.muted{color:#cfcfcf;line-height:1.45}.notice{margin-top:24px;border:1px solid #333;border-radius:8px;padding:20px;color:#ccc}.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.stat{background:#1b1b1b;border:1px solid #333;border-radius:10px;padding:24px}.stat strong{font-size:40px;color:#e21b23}table{width:100%;border-collapse:collapse;background:#1b1b1b;border:1px solid #333;border-radius:10px;overflow:hidden}th,td{padding:14px;border-bottom:1px solid #333;text-align:left}th{color:#e21b23;text-transform:uppercase;font-size:13px}input,select,textarea{width:100%;background:#111;border:1px solid #444;color:#fff;border-radius:6px;padding:12px;margin:6px 0 14px}label{font-weight:800}.actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap}.danger{background:#651018}.login-box{max-width:520px;margin:70px auto}footer{background:#111;text-align:center;color:#999;padding:20px;border-top:1px solid #222}@media(max-width:1000px){.topbar{height:auto;flex-direction:column;align-items:flex-start;padding:20px}nav{flex-wrap:wrap;margin-top:20px}.hero{padding:45px 25px}.hero h2{font-size:38px}.module-grid,.stats{grid-template-columns:1fr}}
