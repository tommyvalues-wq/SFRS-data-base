<%- include('layout-top') %><div class="heading"><h1>Firefighters</h1><% if (user && ['owner','pst'].includes(user.role)) { %><a class="btn" href="/firefighters/new">Add firefighter</a><% } %></div><section class="card"><table><tr><th>Name</th><th>Rank</th><th>Station</th><th>Status</th><th>Roblox ID</th><th></th></tr><% firefighters.forEach(f=>{ %><tr><td><strong><%= f.name %></strong><br><small><%= f.notes || '' %></small></td><td><%= f.rank %></td><td><%= f.station || '-' %></td><td><span class="pill"><%= f.status %></span></td><td><%= f.roblox_id || '-' %></td><td><% if (['owner','pst'].includes(user.role)) { %><a href="/firefighters/<%= f.id %>/edit">Edit</a><form class="inline" method="post" action="/firefighters/<%= f.id %>/delete" onsubmit="return confirm('Delete firefighter?')"><button class="link danger">Delete</button></form><% } %></td></tr><% }) %></table></section><%- include('layout-bottom') %>
