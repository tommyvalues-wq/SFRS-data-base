<%- include('layout-top') %><section class="page"><div class="page-head"><h2>Firefighters</h2><% if(user && ['owner','pst'].includes(user.role)){ %><a class="primary-btn small" href="/firefighters/new">Add firefighter</a><% } %></div><div class="panel"><table><tr><th>Name</th><th>Rank</th><th>Station</th><th>Status</th><th>Roblox ID</th><th></th></tr><% firefighters.forEach(f=>{ %><tr><td><%= f.name %></td><td><%= f.rank %></td><td><%= f.station %></td><td><%= f.status %></td><td><%= f.roblox_id %></td><td><% if(user && ['owner','pst'].includes(user.role)){ %><a href="/firefighters/<%= f.id %>/edit">Edit</a><form class="inline" method="post" action="/firefighters/<%= f.id %>/delete"><button>Delete</button></form><% } %></td></tr><% }) %></table></div></section><%- include('layout-bottom') %>
