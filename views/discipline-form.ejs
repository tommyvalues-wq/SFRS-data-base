<%- include('layout-top') %><section class="card narrow"><h1><%= title %></h1><form method="post" action="<%= c.id ? '/discipline/'+c.id : '/discipline' %>"><label>Firefighter<select name="firefighter_id" required><% firefighters.forEach(f=>{ %><option value="<%= f.id %>" <%= c.firefighter_id===f.id?'selected':'' %>><%= f.name %> — <%= f.rank %></option><% }) %></select></label><label>Type<input name="type" required placeholder="Warning, Suspension, Investigation" value="<%= c.type || '' %>"></label><label>Severity<select name="severity"><% ['Low','Medium','High','Critical'].forEach(s=>{ %><option <%= c.severity===s?'selected':'' %>><%= s %></option><% }) %></select></label><label>Action date<input type="date" name="action_date" required value="<%= c.action_date || new Date().toISOString().slice(0,10) %>"></label><label>Summary<textarea name="summary" required><%= c.summary || '' %></textarea></label><label>Outcome<textarea name="outcome"><%= c.outcome || '' %></textarea></label><button class="btn full">Save action</button></form></section><%- include('layout-bottom') %>
