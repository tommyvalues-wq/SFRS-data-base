<%- include('layout-top') %><section class="card narrow"><h1><%= title %></h1><form method="post" action="<%= f.id ? '/firefighters/'+f.id : '/firefighters' %>"><label>Name<input name="name" required value="<%= f.name || '' %>"></label><label>Rank<input name="rank" required value="<%= f.rank || '' %>"></label><label>Station<input name="station" value="<%= f.station || '' %>"></label><label>Status<select name="status"><% ['Active','Suspended','On Leave','Retired'].forEach(s=>{ %><option <%= f.status===s?'selected':'' %>><%= s %></option><% }) %></select></label><label>Roblox ID<input name="roblox_id" value="<%= f.roblox_id || '' %>"></label><label>Notes<textarea name="notes"><%= f.notes || '' %></textarea></label><button class="btn full">Save</button></form></section><%- include('layout-bottom') %>
