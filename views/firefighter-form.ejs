<%- include('layout-top') %><section class="page"><div class="panel narrow"><h2><%= title %></h2><form method="post" action="<%= f.id ? '/firefighters/'+f.id : '/firefighters' %>"><label>Name<input name="name" value="<%= f.name || '' %>" required></label><label>Roblox ID<input name="roblox_id" value="<%= f.roblox_id || '' %>"></label><label>Rank<input name="rank" value="<%= f.rank || '' %>" required></label><label>Station<input name="station" value="<%= f.station || '' %>"></label><label>Status<select name="status"><% ['Active','Suspended','Inactive','Retired'].forEach(s=>{ %><option <%= (f.status||'Active')===s?'selected':'' %>><%= s %></option><% }) %></select></label><label>Notes<textarea name="notes"><%= f.notes || '' %></textarea></label><button class="primary-btn">Save</button></form></div></section><%- include('layout-bottom') %>
