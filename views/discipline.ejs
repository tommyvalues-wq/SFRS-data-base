<%- include('layout-top') %><section class="page"><div class="page-head"><h2>Disciplinary Actions</h2><a class="primary-btn small" href="/discipline/new">Add action</a></div><div class="panel"><table><tr><th>Date</th><th>Firefighter</th><th>Type</th><th>Severity</th><th>Summary</th><th>Outcome</th><th></th></tr><% cases.forEach(c=>{ %><tr><td><%= c.action_date %></td><td><%= c.firefighter %></td><td><%= c.type %></td><td><%= c.severity %></td><td><%= c.summary %></td><td><%= c.outcome %></td><td><a href="/discipline/<%= c.id %>/edit">Edit</a><form class="inline" method="post" action="/discipline/<%= c.id %>/delete"><button>Delete</button></form></td></tr><% }) %></table></div></section><%- include('layout-bottom') %>
