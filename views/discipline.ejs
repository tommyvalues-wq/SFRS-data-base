<%- include('layout-top') %><div class="heading"><h1>Professional Standards</h1><a class="btn" href="/discipline/new">Add action</a></div><section class="card"><table><tr><th>Date</th><th>Firefighter</th><th>Type</th><th>Severity</th><th>Summary</th><th>Outcome</th><th></th></tr><% cases.forEach(c=>{ %><tr><td><%= c.action_date %></td><td><%= c.firefighter %></td><td><%= c.type %></td><td><span class="pill"><%= c.severity %></span></td><td><%= c.summary %></td><td><%= c.outcome || '-' %></td><td><a href="/discipline/<%= c.id %>/edit">Edit</a><form class="inline" method="post" action="/discipline/<%= c.id %>/delete" onsubmit="return confirm('Delete action?')"><button class="link danger">Delete</button></form></td></tr><% }) %></table></section><%- include('layout-bottom') %>
