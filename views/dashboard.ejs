<%- include('layout-top') %><h1>Dashboard</h1><div class="stats"><div><b><%= stats.firefighters %></b><span>Firefighters</span></div><div><b><%= stats.cases %></b><span>Standards cases</span></div><div><b><%= stats.pst %></b><span>PST members</span></div></div><section class="card"><h2>Recent activity</h2><table><tr><th>When</th><th>Actor</th><th>Action</th><th>Entity</th><th>Details</th></tr><% recent.forEach(r=>{ %><tr><td><%= r.created_at %></td><td><%= r.username || 'System' %></td><td><%= r.action %></td><td><%= r.entity %> #<%= r.entity_id %></td><td><%= r.details %></td></tr><% }) %></table></section><%- include('layout-bottom') %>
