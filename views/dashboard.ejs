<%- include('layout-top') %><section class="page"><h2>Dashboard</h2><div class="stats"><div><b><%= stats.firefighters %></b><span>Firefighters</span></div><div><b><%= stats.cases %></b><span>Disciplinary Actions</span></div><div><b><%= stats.pst %></b><span>PST Members</span></div></div><div class="panel"><h3>Recent audit activity</h3><table><tr><th>When</th><th>Actor</th><th>Action</th><th>Entity</th><th>Details</th></tr><% recent.forEach(r=>{ %><tr><td><%= r.created_at %></td><td><%= r.username || 'System' %></td><td><%= r.action %></td><td><%= r.entity %> #<%= r.entity_id %></td><td><%= r.details %></td></tr><% }) %></table></div></section><%- include('layout-bottom') %>
