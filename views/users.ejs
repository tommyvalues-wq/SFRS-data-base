<%- include('layout-top') %><section class="page"><h2>User Management</h2><div class="panel"><h3>Add or approve user</h3><form class="row-form" method="post" action="/admin/users/add"><input name="roblox_id" placeholder="Roblox ID" required><input name="username" placeholder="Username"><select name="role"><option value="member">Member</option><option value="pst">Professional Standards</option><option value="owner">Owner</option></select><button class="primary-btn small">Add / Update</button></form></div><div class="panel"><table><tr><th>Username</th><th>Roblox ID</th><th>Role</th><th>Allowed</th><th></th></tr><% users.forEach(u=>{ %><tr><form method="post" action="/admin/users/<%= u.id %>/role"><td><%= u.username %></td><td><%= u.roblox_id %></td><td><select name="role"><% Object.keys(roles).forEach(r=>{ %><option value="<%= r %>" <%= u.role===r?'selected':'' %>><%= roles[r] %></option><% }) %></select></td><td><input type="checkbox" name="is_allowed" <%= u.is_allowed?'checked':'' %>></td><td><button>Save</button></td></form></tr><% }) %></table></div></section><%- include('layout-bottom') %>
