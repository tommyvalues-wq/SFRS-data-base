<%- include('layout-top') %><h1>User management</h1><section class="card"><h2>Add or approve Roblox user</h2><form class="gridform" method="post" action="/admin/users/add"><input name="roblox_id" required placeholder="Roblox user ID"><input name="username" placeholder="Username"><select name="role"><option value="member">Member</option><option value="pst">Professional Standards Team</option><option value="owner">Owner</option></select><button class="btn">Add / update</button></form></section><section class="card"><table><tr><th>Username</th><th>Roblox ID</th><th>Role</th><th>Allowed</th><th></th></tr><% users.forEach(u=>{ %><tr><form method="post" action="/admin/users/<%= u.id %>/role"><td><%= u.username %></td><td><%= u.roblox_id %></td><td><select name="role"><% Object.keys(roles).forEach(r=>{ %><option value="<%= r %>" <%= u.role===r?'selected':'' %>><%= roles[r] %></option><% }) %></select></td><td><input type="checkbox" name="is_allowed" <%= u.is_allowed?'checked':'' %>></td><td><button>Save</button></td></form></tr><% }) %></table></section><%- include('layout-bottom') %>
