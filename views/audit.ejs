<%- include('layout-top') %><h1>Audit log</h1><section class="card"><table><tr><th>When</th><th>Actor</th><th>Action</th><th>Entity</th><th>Details</th></tr><% rows.forEach(r=>{ %><tr><td><%= r.created_at %></td><td><%= r.username || 'System' %></td><td><%= r.action %></td><td><%= r.entity %> #<%= r.entity_id %></td><td><%= r.details %></td></tr><% }) %></table></section><%- include('layout-bottom') %>
