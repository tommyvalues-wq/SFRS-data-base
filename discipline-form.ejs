<%- include('layout-top') %><section class="page"><h2>Dashboard</h2><div class="stats"><div class="stat"><strong><%= stats.firefighters %></strong><p>Firefighters</p></div><div class="stat"><strong><%= stats.cases %></strong><p>Disciplinary Cases</p></div><div class="stat"><strong><%= stats.pst %></strong><p>PST Users</p></div></div><h2 style="margin-top:30px">Recent Audit Activity</h2><div class="card"><% if(!recent.length){ %><p class="muted">No recent activity.</p><% } %><% recent.forEach(r=>{ %><p><strong><%= r.created_at %></strong> — <%= r.username %> <%= r.action %> <%= r.entity %> #<%= r.entity_id %> <span class="muted"><%= r.details %></span></p><% }) %></div></section><%- include('layout-bottom') %>
