<%- include('layout-top') %><section class="page"><div class="actions"><h2>Disciplinary Actions</h2><a class="btn" href="/discipline/new">Add Action</a></div><table><tr><th>Date</th><th>Firefighter</th><th>Type</th><th>Severity</th><th>Summary</th><th>Outcome</th><th>Actions</th></tr><% cases.forEach(c=>{ %><tr><td><%= c.action_date %></td><td><%= c.firefighter %></td><td><%= c.type %></td><td><%= c.severity %></td><td><%= c.summary %></td><td><%= c.outcome %></td><td><a class="btn" href="/discipline/<%= c.id %>/edit">Edit</a><form method="post" action="/discipline/<%= c.id %>/delete" style="display:inline"><button class="btn danger">Delete</button></form></td></tr><% }) %></table></section><%- include('layout-bottom') %>
